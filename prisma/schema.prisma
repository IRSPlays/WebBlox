generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String  @id @default(uuid())
  username      String  @unique
  avatar_colors String  // JSON string or hex code
  games         Game[]
}

model Game {
  id          String   @id @default(uuid())
  creatorId   String
  title       String
  json_schema String   // JSON string of the world schema
  creator     User     @relation(fields: [creatorId], references: [id])
}
